# LangChain Examples - Environment Variables Template
# Copy this file to .env and fill in your actual keys

# Required for OpenAI models (ChatOpenAI, OpenAIEmbeddings, OpenAI)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Required for RAG pipeline with Pinecone (03_rag_pipeline.py)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=langchain-demo
